{
  "name": "@comatrix/api-contracts",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema.graphql": "./src/schema.graphql"
  },
  "scripts": {
    "build": "yarn codegen && tsc -p tsconfig.json",
    "typecheck": "yarn codegen && tsc -p tsconfig.json --noEmit",
    "test": "yarn codegen && tsc -p tsconfig.json --noEmit",
    "lint": "yarn codegen && tsc -p tsconfig.json --noEmit",
    "codegen": "node scripts/generate-schema-ts.mjs && graphql-codegen --config codegen.yml"
  },
  "dependencies": {
    "@graphql-typed-document-node/core": "^3.2.0",
    "graphql": "^16.11.0"
  }
}
